# === Python 基础忽略 ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# === PyInstaller 打包生成文件 (必须要忽略) ===
# 打包过程的临时文件
build/
# 打包生成的最终 exe 文件夹
dist/
# PyInstaller 生成的配置文件
*.spec

# === 虚拟环境 ===
# 避免把你的本地环境传上去
venv/
.venv/
env/
.env
# 如果你习惯把环境放在项目里，也可以加这一行
yys_env/

# === 项目运行时生成的临时文件 ===
# 视觉诊断生成的调试图
debug_vision_dump.png
debug_screenshot.png
# 通配符忽略所有 debug 开头的图片
debug_*.png
debug_*.jpg

# === IDE 配置文件 (建议忽略) ===
# VS Code
.vscode/
# Pycharm
.idea/

# === 其他杂项 ===
# 系统生成的缩略图缓存
Thumbs.db
.DS_Store
# 日志文件
*.log